{
  "mcpServers": {
    "cram-ai": {
      "command": "cram",
      "args": ["mcp", "--repo", "/Users/vishbay/cram-ai"],
      "env": {
        "PATH": "/Users/vishbay/cram-ai/.venv/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cram_session_start.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__cram-ai__get_context",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/cram_post_context.py"
          }
        ]
      }
    ]
  }
}
